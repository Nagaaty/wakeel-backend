# ================================================================
#  Wakeel Backend — Environment Variables
#  Copy this file to .env and fill in your values
#  Only the first 3 variables are REQUIRED to run
# ================================================================

# ── REQUIRED ──────────────────────────────────────────────────
PORT=5000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wakeel
DB_USER=postgres
DB_PASSWORD=your_postgresql_password_here
JWT_SECRET=change_this_to_any_random_string_minimum_32_characters

# ── OPTIONAL: AI Features (free $5 credit at console.anthropic.com) ──
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPTIONAL: Email notifications ─────────────────────────────
# Use Gmail: enable 2FA → Google Account → App Passwords → create one
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your_16_char_app_password
# EMAIL_FROM=Wakeel <noreply@wakeel.eg>

# ── OPTIONAL: Paymob (Egyptian payment gateway) ───────────────
# PAYMOB_API_KEY=
# PAYMOB_INTEGRATION_ID=
# PAYMOB_HMAC_SECRET=

# ── OPTIONAL: Video calls (daily.co — free tier available) ────
# DAILY_API_KEY=
# DAILY_DOMAIN=your-domain.daily.co

# ── OPTIONAL: SMS/WhatsApp (Twilio — free trial available) ────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=+1xxxxxxxxxx

# ── OPTIONAL: Push notifications (Firebase — always free) ─────
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

NODE_ENV=development
FRONTEND_URL=http://localhost:3000
