# ================================================================
#  Wakeel Mobile — Environment Variables
#  Copy this file to .env and set your backend URL
# ================================================================

# Your backend server URL
#
# ┌─────────────────────────────────────────────────────────────┐
# │ WHERE ARE YOU TESTING?          │ SET THIS TO               │
# ├─────────────────────────────────┼───────────────────────────┤
# │ Android EMULATOR on your PC     │ http://10.0.2.2:5000      │
# │ iOS SIMULATOR on your Mac       │ http://localhost:5000      │
# │ PHYSICAL phone (most common)    │ http://YOUR_PC_IP:5000     │
# └─────────────────────────────────┴───────────────────────────┘
#
# Find your PC's IP:
#   Windows: open CMD → type ipconfig → look for IPv4 Address
#   Mac:     open Terminal → type: ifconfig | grep "inet "
#
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:5000

EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
