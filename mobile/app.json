{
  "expo": {
    "name": "Wakeel",
    "slug": "wakeel-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wakeel",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#070809"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "eg.wakeel.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for video consultations and profile photos",
        "NSMicrophoneUsageDescription": "Used for audio and video consultations",
        "NSPhotoLibraryUsageDescription": "Used to upload documents and profile photos",
        "NSFaceIDUsageDescription": "Used for biometric login",
        "NSLocationWhenInUseUsageDescription": "Used to show nearby lawyers and in-person meeting locations"
      },
      "associatedDomains": [
        "applinks:wakeel.eg"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070809"
      },
      "package": "eg.wakeel.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "wakeel.eg",
              "pathPrefix": "/"
            },
            {
              "scheme": "http",
              "host": "wakeel.eg",
              "pathPrefix": "/"
            },
            {
              "scheme": "wakeel"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ],
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Used for video consultations"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Used for audio and video consultations"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select and attach case files."
        }
      ],
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c17453bb-ee2d-4512-b362-1446caa7a167"
      }
    }
  }
}
